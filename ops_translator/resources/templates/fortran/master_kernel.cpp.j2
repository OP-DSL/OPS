{% else %}
#include "ops_f2c_prelude_v2.h"
{% endif %}

namespace f2c = ops::f2c;

{% endblock %}

{% block dim_struct %}
{% endblock %}

{% block const_decls required %}
{% endblock %}

{% block header_includes %}
// user kernel files
{% for lh,p in app.uniqueLoops() %}
#include "{{lh.kernel}}_f2c_kernel.{{include_extension}}"
{% endfor %}
{% endblock %}
