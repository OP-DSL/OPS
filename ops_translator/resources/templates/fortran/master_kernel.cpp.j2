
{% block ops_headers %}
// headers
#define OPS_{{app.global_dim}}D
{% if soa_set %}
#define OPS_SOA
{% endif %}
#define OPS_API 2
#include "ops_lib_core.h"

#ifdef OPS_MPI
#include "ops_mpi_core.h"
#include <limits>
#endif

{% if target.name == "f2c_cuda" or target.name == "f2c_hip" %}
