        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name(arg)}}
        {%- else -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "out")}},
           hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "in")}}
