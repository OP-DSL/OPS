    {% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_read or arg is ops_rw %}
    ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_mem_strm, arg{{arg.id}}_axis_out, {{num_pkts(arg)}});
        {% endif %}
    {% endfor %}
    {#{% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_read or arg is ops_rw %}
        ops::hls::axisLoopbackV2<mem_data_width, {{axis_data_width(arg)-}}, data_width>(arg{{ilh.getArg(ilh.dat_swap_map[arg.dat_id]).id}}_axis_in, arg{{arg.id}}_axis_out, num_pkts);
        {% endif %}
    {% endfor %}#}
}

static void datamover_outerloop_{{ilh.id}}_loopback(
        const unsigned int iter,
        const unsigned int num_pkts
    {#{%- if ilh.isMultiDim() -%}
        {%- for m_dim in ilh.getMultidimList() -%}
        ,{{"\n"}}        const unsigned int num_pkts_d{{m_dim}}
        {%- endfor -%}
    {%- endif -%}#}
    {%- for arg in ilh.joint_args|ops_dat -%}
    {%- if (arg is not ops_rw) and arg is is_arg_swap(ilh) -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name(arg)}}
        {%- else -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "out")}},
            hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "in")}}
        {%- endif -%}
    {%- endfor -%}
        )
{
    for (unsigned int i = 0; i < iter; i++)
    {
        #pragma HLS PIPELINE REWIND
    #ifdef DEBUG_LOG
        printf("[KERNEL_DEBUG]|%s| Calling loopback. i:%d\n", __func__, i);
    #endif
        datamover_outerloop_{{ilh.id}}_loopback_dataflow_region(num_pkts
        {#{%- if ilh.isMultiDim() -%}
            {%- for m_dim in ilh.getMultidimList() -%}
                ,{{"\n"}}        num_pkts_d{{m_dim}}
            {%- endfor -%}
        {%- endif -%}#}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if (arg is not ops_rw) and arg is is_arg_swap(ilh) -%}
                ,{{"\n"}}        {{axis_name(arg)}}
            {%- else -%}
                ,{{"\n"}}        {{axis_name_t2(arg, "out")}}, {{axis_name_t2(arg, "in")}}
            {%- endif -%}
        {%- endfor -%}
        );
    } 
}
{% endblock %}

{% block datamover_prototype %}
{{super()}}
