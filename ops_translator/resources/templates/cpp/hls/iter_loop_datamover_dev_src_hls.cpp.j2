{% extends "cpp/hls/iter_loop_datamover_dev_inc_hls.hpp.j2" %}

{% block header_block %}
#include <datamover_outerloop_{{ilh.id}}.hpp>
{% endblock %}

{% block datamover_dataflow_region %}
static void datamover_outerloop_{{ilh.id}}_dataflow_region_read(
        const unsigned int num_pkts,
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const unsigned int num_pkts_d{{m_dim}},
        {% endfor %}
    {% endif %}#}
        const ops::hls::MemConfig& memconfig
    {%- if ilh.isMultiDim() -%}
        {%- for m_dim in ilh.getMultidimList() -%}
        ,{{"\n"}}        const ops::hls::MemConfig& memconfig_d{{m_dim}}
        {%- endfor -%}
    {%- endif -%}
    {#{%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_read or arg is ops_rw -%}
        ,{{"\n"}}       ops::hls::SizeType& arg{{arg.id}}_gridSize
        {%- endif -%}
    {%- endfor -%}#}
    {%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_read or arg is ops_rw -%}
        ,{{"\n"}}        ap_uint<mem_data_width>* arg{{arg.id}}
        {%- endif -%}
    {%- endfor -%}
    {%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_read -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name(arg)}}
        {%- elif arg is ops_rw -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "out")}}
        {%- endif -%}
    {%- endfor -%})
{
#pragma HLS DATAFLOW
    {% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_read_or_rw%}
    static ::hls::stream<ap_uint<mem_data_width>> arg{{arg.id}}_read_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_read_mem_strm depth = max_depth_v16
            {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
    static ::hls::stream<ap_uint<{{axis_data_width(arg)-}}>> arg{{arg.id}}_read_reduced_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_read_reduced_mem_strm depth = max_depth_v8
            {% endif %}
        {% endif %}
    {% endfor %}
    unsigned int total_xblocks = memconfig.total_xblocks;
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
    ops::hls::mem2stream<mem_data_width>(arg{{arg.id}}, arg{{arg.id}}_read_mem_strm, total_xblocks);
    {% endfor %}
    
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
    ops::hls::stream2streamStepdown<mem_data_width, {{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, arg{{arg.id}}_read_reduced_mem_strm, {{num_beats(arg)}});
        {% endif %}
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
            {% if arg is ops_read %}
    ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_reduced_mem_strm, {{axis_name(arg)}}, {{num_pkts(arg)}});
            {% elif arg is ops_rw %}
    ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_reduced_mem_strm, {{axis_name_t2(arg, "out")}}, {{num_pkts(arg)}});
            {% endif %}
        {% else %}
            {% if arg is ops_read %}
    ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, {{axis_name(arg)}}, {{num_pkts(arg)}});
            {% elif arg is ops_rw %}
    ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, {{axis_name_t2(arg, "out")}}, {{num_pkts(arg)}});
            {% endif %}
        {% endif %}
    {% endfor %}
    {#{% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_read %}
    ops::hls::memReadGridV2<mem_data_width, {{axis_data_width(arg)-}}, data_width>(arg{{arg.id}}, {{axis_name(arg)}}, arg{{arg.id}}_gridSize, range);
        {% elif arg is ops_rw %}
    ops::hls::memReadGridV2<mem_data_width, {{axis_data_width(arg)-}}, data_width>(arg{{arg.id}}, {{axis_name_t2(arg, "out")}}, arg{{arg.id}}_gridSize, range);
        {% endif %}
    {% endfor %}#}
}

static void datamover_outerloop_{{ilh.id}}_dataflow_region_write(
        const unsigned int num_pkts,
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const unsigned int num_pkts_d{{m_dim}},
        {% endfor %}
    {% endif %}#}
        const ops::hls::MemConfig& memconfig
    {%- if ilh.isMultiDim() -%}
        {%- for m_dim in ilh.getMultidimList() -%}
        ,{{"\n"}}        const ops::hls::MemConfig& memconfig_d{{m_dim}}
        {%- endfor -%}
    {%- endif -%}
    {#ops::hls::AccessRange& range
    {%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_write or arg is ops_rw -%}
        ,{{"\n"}}       ops::hls::SizeType& arg{{arg.id}}_gridSize
        {%- endif -%}
    {%- endfor -%}#}
    {%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_write or arg is ops_rw -%}
        ,{{"\n"}}        ap_uint<mem_data_width>* arg{{arg.id}}
        {%- endif -%}
    {%- endfor -%}
    {%- for arg in ilh.joint_args|ops_dat -%}
        {%- if arg is ops_write -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name(arg)}}
        {%- elif arg is ops_rw -%}
        ,{{"\n"}}        hls::stream<ap_axiu<{{axis_data_width(arg)-}}, 0, 0, 0>>& {{axis_name_t2(arg, "in")}}
        {%- endif -%}
    {%- endfor -%}
        )
{
    {% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_write_or_rw and arg is not read_only_rw %}
    static ::hls::stream<ap_uint<mem_data_width>> arg{{arg.id}}_write_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_write_mem_strm depth = max_depth_v16
            {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
    static ::hls::stream<ap_uint<{{axis_data_width(arg)-}}>> arg{{arg.id}}_write_reduced_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_write_reduced_mem_strm depth = max_depth_v8
            {% endif %}
        {% endif %}
    {% endfor %}
    unsigned int total_xblocks = memconfig.total_xblocks;

#pragma HLS DATAFLOW
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if arg is ops_write_or_rw %}
            {% if arg is read_only_rw %}
    ops::hls::axisTerminate<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, {{num_pkts(arg)}});
            {% else %}
                {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
                    {% if arg is ops_write %}
    ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name(arg)}}, arg{{arg.id}}_write_reduced_mem_strm, {{num_pkts(arg)}});
                    {% else %}
    ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, arg{{arg.id}}_write_reduced_mem_strm, {{num_pkts(arg)}});
                    {% endif %}
                {% else %}
                    {% if arg is ops_write %}
    ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name(arg)}}, arg{{arg.id}}_write_mem_strm, {{num_pkts(arg)}});
                    {% else %}
    ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, arg{{arg.id}}_write_mem_strm, {{num_pkts(arg)}});
                    {% endif %}
                {% endif %}
            {% endif %}
        {% endif %}    
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
            {% if arg is not read_only_rw %}
    ops::hls::stream2streamStepup<{{axis_data_width(arg)-}}, mem_data_width>(arg{{arg.id}}_write_reduced_mem_strm, arg{{arg.id}}_write_mem_strm, {{num_beats(arg)}});
            {% endif %}
        {% endif %}
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if arg is not read_only_rw %}
    ops::hls::stream2mem<mem_data_width>(arg{{arg.id}}, arg{{arg.id}}_write_mem_strm, total_xblocks);
        {% endif %}
    {% endfor %}
    {#{% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_write %}
    ops::hls::memWriteGridSimpleV2<mem_data_width, {{axis_data_width(arg)-}}, data_width>(arg{{arg.id}}, {{axis_name(arg)}}, arg{{arg.id}}_gridSize, range);
        {% elif arg is ops_rw %}
            {% if arg is read_only_rw %}
    ops::hls::memWriteGridTerminate<mem_data_width, {{axis_data_width(arg)-}}, data_width>({{axis_name_t2(arg, "in")}}, arg{{arg.id}}_gridSize, range);
            {% else %}
    ops::hls::memWriteGridSimpleV2<mem_data_width, {{axis_data_width(arg)-}}, data_width>(arg{{arg.id}}, {{axis_name_t2(arg, "in")}}, arg{{arg.id}}_gridSize, range);
            {% endif %}
        {% endif %}
    {% endfor %}#}
}

static void datamover_outerloop_{{ilh.id}}_dataflow_read_write_dataflow_region(
        const unsigned int num_pkts,
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const unsigned int num_pkts_d{{m_dim}},
        {% endfor %}
    {% endif %}#}
        const ops::hls::MemConfig& memconfig,
    {% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const ops::hls::MemConfig& memconfig_d{{m_dim}},
        {% endfor %}
    {% endif %}
    {% for arg in ilh.joint_args|ops_dat %}
        ap_uint<mem_data_width>* arg{{(arg.id)}},
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat %}
        {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name(arg)-}}{{"," if not loop.last}}
        {% else %}
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "out")-}},
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
        {% endif %}
    {% endfor %})    
{
    {% for arg in ilh.joint_args|ops_dat %}
        {% if arg is ops_read_or_rw%}
    static ::hls::stream<ap_uint<mem_data_width>> arg{{arg.id}}_read_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_read_mem_strm depth = max_depth_v16
            {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
    static ::hls::stream<ap_uint<{{axis_data_width(arg)-}}>> arg{{arg.id}}_read_reduced_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_read_reduced_mem_strm depth = max_depth_v8
            {% endif %}
        {% endif %}
        {% if arg is ops_write_or_rw and arg is not read_only_rw %}
    static ::hls::stream<ap_uint<mem_data_width>> arg{{arg.id}}_write_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_write_mem_strm depth = max_depth_v16
            {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
    static ::hls::stream<ap_uint<{{axis_data_width(arg)-}}>> arg{{arg.id}}_write_reduced_mem_strm;
    #pragma HLS STREAM variable = arg{{arg.id}}_write_reduced_mem_strm depth = max_depth_v8
            {% endif %}
        {% endif %}
    {% endfor %}
unsigned int total_xblocks = memconfig.total_xblocks;
#pragma HLS DATAFLOW
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
        ops::hls::mem2stream<mem_data_width>(arg{{arg.id}}, arg{{arg.id}}_read_mem_strm, total_xblocks);
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
        ops::hls::stream2streamStepdown<mem_data_width, {{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, arg{{arg.id}}_read_reduced_mem_strm, {{num_beats(arg)}});
        {% endif %}
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_read_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
            {% if arg is ops_read %}
        ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_reduced_mem_strm, {{axis_name(arg)}}, {{num_pkts(arg)}});
            {% elif arg is ops_rw %}
        ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_reduced_mem_strm, {{axis_name_t2(arg, "out")}}, {{num_pkts(arg)}});
            {% endif %}
        {% else %}
            {% if arg is ops_read %}
        ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, {{axis_name(arg)}}, {{num_pkts(arg)}});
            {% elif arg is ops_rw %}
        ops::hls::stream2axis<{{axis_data_width(arg)-}}>(arg{{arg.id}}_read_mem_strm, {{axis_name_t2(arg, "out")}}, {{num_pkts(arg)}});
            {% endif %}
        {% endif %}
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if arg is ops_write_or_rw %}
            {% if arg is read_only_rw %}
        ops::hls::axisTerminate<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, {{num_pkts(arg)}});
            {% else %}
                {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
                    {% if arg is ops_write %}
        ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name(arg)}}, arg{{arg.id}}_write_reduced_mem_strm, {{num_pkts(arg)}});
                    {% else %}
        ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, arg{{arg.id}}_write_reduced_mem_strm, {{num_pkts(arg)}});
                    {% endif %}
                {% else %}
                    {% if arg is ops_write %}
        ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name(arg)}}, arg{{arg.id}}_write_mem_strm, {{num_pkts(arg)}});
                    {% else %}
        ops::hls::axis2stream<{{axis_data_width(arg)-}}>({{axis_name_t2(arg, "in")}}, arg{{arg.id}}_write_mem_strm, {{num_pkts(arg)}});
                    {% endif %}
                {% endif %}
            {% endif %}
        {% endif %}    
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if config["vector_factor"] * ilh.dats[arg.dat_id][0].dim < config["mem_vector_factor"] %}
            {% if arg is not read_only_rw %}
        ops::hls::stream2streamStepup<{{axis_data_width(arg)-}}, mem_data_width>(arg{{arg.id}}_write_reduced_mem_strm, arg{{arg.id}}_write_mem_strm, {{num_beats(arg)}});
            {% endif %}
        {% endif %}
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat|ops_write_or_rw %}
        {% if arg is not read_only_rw %}
        ops::hls::stream2mem<mem_data_width>(arg{{arg.id}}, arg{{arg.id}}_write_mem_strm, total_xblocks);
        {% endif %}
    {% endfor %}
}

static void datamover_outerloop_{{ilh.id}}_dataflow_read_write(
        const unsigned int iter,
        const unsigned int num_pkts,
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const unsigned int num_pkts_d{{m_dim}},
        {% endfor %}
    {% endif %}#}
        const ops::hls::MemConfig& memconfig,
    {% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
        const ops::hls::MemConfig& memconfig_d{{m_dim}},
        {% endfor %}
    {% endif %}
    {% for arg in ilh.joint_args|ops_dat %}
        ap_uint<mem_data_width>* arg{{(arg.id)}},
    {% endfor %}
    {% for arg in ilh.joint_args|ops_dat %}
        {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name(arg)-}}{{"," if not loop.last}}
        {% else %}
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "out")-}},
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
        {% endif %}
    {% endfor %})    
{
    for (unsigned int i = 0; i < iter/2; i++)
    {
    //#pragma HLS PIPELINE REWIND
    #ifdef DEBUG_LOG
        printf("[KERNEL_DEBUG]|%s| Calling datamover. i:%d\n", __func__, i);
    #endif
        datamover_outerloop_{{ilh.id}}_dataflow_read_write_dataflow_region(
                num_pkts,
            {#{% if ilh.isMultiDim() %}
                {% for m_dim in ilh.getMultidimList() %}
                num_pkts_d{{m_dim}},
                {% endfor %}
            {% endif %}#}
                memconfig,
            {% if ilh.isMultiDim() %}
                {% for m_dim in ilh.getMultidimList() %}
                memconfig_d{{m_dim}},
                {% endfor %}
            {% endif %}
            {% for arg in ilh.joint_args|ops_dat %}
                arg{{(arg.id)}},
            {% endfor %}
            {% for arg in ilh.joint_args|ops_dat %}
                {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}
                {{axis_name(arg)-}}{{"," if not loop.last}}
                {% else %}
                {{axis_name_t2(arg, "out")-}},
                {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
                {% endif %}
            {% endfor %}
        );
        datamover_outerloop_{{ilh.id}}_dataflow_read_write_dataflow_region(
                num_pkts,
                {#{% if ilh.isMultiDim() %}
                    {% for m_dim in ilh.getMultidimList() %}
                num_pkts_d{{m_dim}},
                    {% endfor %}
                {% endif %}#}
                memconfig,
                {% if ilh.isMultiDim() %}
                    {% for m_dim in ilh.getMultidimList() %}
                memconfig_d{{m_dim}},
                    {% endfor %}
                {% endif %}
                {% for arg in ilh.joint_args|ops_dat %}
                arg{{ilh.getSwapArg(arg).id}},
                {% endfor %}
                {% for arg in ilh.joint_args|ops_dat %}
                    {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}
                {{axis_name(arg)-}}{{"," if not loop.last}}
                    {% else %}
                {{axis_name_t2(arg, "out")-}},
                {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
                    {% endif %}
                {% endfor -%}
        );
    }
}

static void datamover_outerloop_{{ilh.id}}_loopback_dataflow_region(
        const unsigned int num_pkts
    {#{%- if ilh.isMultiDim() -%}
        {%- for m_dim in ilh.getMultidimList() -%}
        ,{{"\n"}}        const unsigned int num_pkts_d{{m_dim}}
