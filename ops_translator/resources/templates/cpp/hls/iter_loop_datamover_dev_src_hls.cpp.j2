        {% for m_dim in ilh.getMultidimList() %}
    ops::hls::AccessRange range_d{{m_dim}};
        {% endfor %}
    {% endif %}#}
    {% for i in range(ndim) %}
    range.start[{{i}}] = range_start_{{i}};
    range.end[{{i}}] = range_end_{{i}};
    {% endfor%}
    range.dim = {{ndim}};
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
            {% for i in range(ndim) %}
                {% if i == 0 %}
    range_d{{m_dim}}.start[{{i}}] = range_start_{{i}} * {{m_dim}};
    range_d{{m_dim}}.end[{{i}}] = range_end_{{i}} * {{m_dim}};
                {% else %}
    range_d{{m_dim}}.start[{{i}}] = range_start_{{i}};
    range_d{{m_dim}}.end[{{i}}] = range_end_{{i}};
                {% endif %}
            {% endfor%}
    range_d{{m_dim}}.dim = {{ndim}};
        {% endfor %}
    {% endif %}#}

    ops::hls::SizeType read_gridSize = { {% for i in range(config["ops_max_dim"]) -%}{% if i < ndim %}gridSize_{{i}}{{", " if (not loop.last)}}{% else %}1{{", " if (not loop.last)}}{% endif %}{% endfor %} };
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}    
    unsigned short gridSize_0_d{{m_dim}} = gridSize_0 * {{m_dim}};
    ops::hls::SizeType read_gridSize_d{{m_dim}} = { {% for i in range(config["ops_max_dim"]) -%}{% if i < ndim %}gridSize_{{i}}{{"_d" if i == 0}}{{m_dim if i == 0}}{{", " if (not loop.last)}}{% else %}1{{", " if (not loop.last)}}{% endif %}{% endfor %} };
        {% endfor %}
    {% endif %}#}
    unsigned int loopback_itr = outer_itr - 1 >= 0 ? outer_itr - 1 : 0;

#ifdef DEBUG_LOG
    printf("[KERNEL_DEBUG]|%s| starting datamover TOP range:(%d,%d,%d) ---> (%d,%d,%d)\n", __func__,
            range.start[0], range.start[1], range.start[2], range.end[0], range.end[1], range.end[2]);
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    printf("[KERNEL_DEBUG]|%s| starting datamover TOP range_d{{m_dim}}:(%d,%d,%d) ---> (%d,%d,%d)\n", __func__,
            range_d{{m_dim}}.start[0], range_d{{m_dim}}.start[1], range_d{{m_dim}}.start[2], range_d{{m_dim}}.end[0], range_d{{m_dim}}.end[1], range_d{{m_dim}}.end[2]);
        {% endfor %}
    {% endif %}#}
    printf("[KERNEL_DEBUG]|%s| read_gridSize: (%d, %d, %d), \n", __func__,
            read_gridSize[0], read_gridSize[1], read_gridSize[2]);
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    printf("[KERNEL_DEBUG]|%s| read_gridSize_d{{m_dim}}: (%d, %d, %d), \n", __func__,
            read_gridSize_d{{m_dim}}[0], read_gridSize_d{{m_dim}}[1], read_gridSize_d{{m_dim}}[2]);
        {% endfor %}
    {% endif %}#}
#endif 

    constexpr unsigned int num_of_pkts_per_bytes = mem_data_width / axis_data_width;
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    constexpr unsigned int num_of_pkts_per_bytes_d{{m_dim}} = mem_data_width / {{config["data_width"] * config["vector_factor"] * m_dim}};
        {% endfor %}
    {% endif %}#}
    ops::hls::MemConfig config;
    {% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    ops::hls::MemConfig config_d{{m_dim}};
        {% endfor %}
    {% endif %}
    ops::hls::genMemConfig<mem_data_width, axis_data_width, data_width>(read_gridSize, range, config);
    {% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    ops::hls::multidimConfigConverter<{{m_dim}}>(config, config_d{{m_dim}});
        {% endfor %}
    {% endif %}
    const unsigned int num_beats = config.total_xblocks;
    const unsigned int num_pkts = num_of_pkts_per_bytes * config.total_xblocks;
    {#{% if ilh.isMultiDim() %}
        {% for m_dim in ilh.getMultidimList() %}
    const unsigned int num_pkts_d{{m_dim}} = num_of_pkts_per_bytes_d{{m_dim}} * config_d{{m_dim}}.total_xblocks;
        {% endfor %}
    {% endif %}#}
    {% if config["datamover_mode"] == 3 %}
    if (is_loopback)
    {
    {% endif %}
    {% if config["datamover_mode"] == 3 or config["datamover_mode"] == 1 %}
        datamover_outerloop_{{ilh.id}}_dataflow_region_read(
                num_pkts,
        {#{% if ilh.isMultiDim() %}
            {% for m_dim in ilh.getMultidimList() %}
                num_pkts_d{{m_dim}},
            {% endfor %}
        {% endif %}#}
                config
        {%- if ilh.isMultiDim() -%}
            {%- for m_dim in ilh.getMultidimList() -%}
                ,{{"\n"}}                config_d{{m_dim}}
            {%- endfor -%}
        {%- endif -%}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if arg is ops_read or arg is ops_rw -%}
                ,{{"\n"}}                arg{{arg.id}} 
            {%- endif -%}
        {%- endfor -%}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if arg is ops_read -%}
                ,{{"\n"}}                {{axis_name(arg)}}
            {%- elif arg is ops_rw -%}
                ,{{"\n"}}                {{axis_name_t2(arg, "out")}}
            {%- endif -%}
        {%- endfor -%}
        );

        datamover_outerloop_{{ilh.id}}_loopback(loopback_itr, num_pkts
        {#{%- if ilh.isMultiDim() -%}
            {%- for m_dim in ilh.getMultidimList() -%}
                ,{{"\n"}}                num_pkts_d{{m_dim}}
            {%- endfor -%}
        {%- endif -%}#}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if (arg is not ops_rw) and arg is is_arg_swap(ilh) -%}
                ,{{"\n"}}                {{axis_name(arg)}}
            {%- else -%}
                ,{{"\n"}}                {{axis_name_t2(arg, "out")}}, {{axis_name_t2(arg, "in")}}
            {%- endif -%}
        {%- endfor -%}
        );

        datamover_outerloop_{{ilh.id}}_dataflow_region_write(
                num_pkts,
        {#{% if ilh.isMultiDim() %}
            {% for m_dim in ilh.getMultidimList() %}
                num_pkts_d{{m_dim}},
            {% endfor %}
        {% endif %}#}
                config
        {%- if ilh.isMultiDim() -%}
            {%- for m_dim in ilh.getMultidimList() -%}
                ,{{"\n"}}                config_d{{m_dim}}
            {%- endfor -%}
        {%- endif -%}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if arg is ops_write or arg is ops_rw -%}
                ,{{"\n"}}                arg{{arg.id}} 
            {%- endif -%}
        {%- endfor -%}
        {%- for arg in ilh.joint_args|ops_dat -%}
            {%- if arg is ops_write -%}
                ,{{"\n"}}                {{axis_name(arg)}}
            {%- elif arg is  ops_rw -%}
                ,{{"\n"}}                {{axis_name_t2(arg, "in")}}
            {%- endif -%}
        {%- endfor -%}
        );
    {% endif %}
    {% if config["datamover_mode"] == 3 %}
    }
    else
    {
    {% endif %}
    {% if config["datamover_mode"] == 3 or config["datamover_mode"] == 2 %}
        datamover_outerloop_{{ilh.id}}_dataflow_read_write(
                outer_itr,
                num_pkts,
        {#{% if ilh.isMultiDim() %}
            {% for m_dim in ilh.getMultidimList() %}
                num_pkts_d{{m_dim}},
            {% endfor %}
        {% endif %}#}
                config,
        {% if ilh.isMultiDim() %}
                {% for m_dim in ilh.getMultidimList() %}
                config_d{{m_dim}},
                {% endfor %}
        {% endif %}
        {% for arg in ilh.joint_args|ops_dat %}
                arg{{(arg.id)}},
        {% endfor %}
        {% for arg in ilh.joint_args|ops_dat %}
                {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}
            {{axis_name(arg)-}}{{"," if not loop.last}}
            {% else %}
                {{axis_name_t2(arg, "out")-}},
                {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
            {% endif %}
        {% endfor %}
            );
    {% endif %}
    {% if config["datamover_mode"] == 3 %}
    }
    {% endif %}
}


