{% macro maxi_name(arg) -%}
arg{{arg.id}}_{{"in" if arg is ops_read}}{{"out" if arg is ops_write}}{{"inout" if arg is ops_rw}}
{%- endmacro -%}
{% macro axis_name(arg) -%}
    {%- if arg is not ops_rw -%}
arg{{arg.id}}_axis_{{"out" if (arg is ops_read) else ("in" if (arg is ops_write))}}
    {%- endif -%}
{%- endmacro -%}
{% macro axis_name_t2(arg, suffix) -%}
arg{{arg.id}}_axis_{{suffix}}
{%- endmacro -%}
{% macro axis_data_width(arg) -%}
    {%- if ilh.dats[arg.dat_id][0].isMultiDim() -%}
multidim_axis_data_width_{{ilh.id}}_{{ilh.dats[arg.dat_id][0].ptr}}
    {%- else -%}
axis_data_width
    {%- endif -%}
{%- endmacro -%}
{% macro num_pkts(arg) -%}
    {%- if ilh.dats[arg.dat_id][0].isMultiDim() -%}
num_pkts
    {%- else -%}
num_pkts
    {%- endif -%}
{%- endmacro -%}
{% macro num_beats(arg) -%}
    {%- if ilh.dats[arg.dat_id][0].isMultiDim() -%}
memconfig_d{{ilh.dats[arg.dat_id][0].dim}}.total_xblocks
    {%- else -%}
total_xblocks
    {%- endif -%}
{%- endmacro -%}
{% macro memconfig(arg) -%}
    {%- if ilh.dats[arg.dat_id][0].isMultiDim() -%}
memconfig_d{{ilh.dats[arg.dat_id][0].dim}}
    {%- else -%}
memconfig
    {%- endif -%}
{%- endmacro -%}
{% macro axis_data_width_datid(dat_id) -%}
    {%- if ilh.dats[dat_id][0].isMultiDim() -%}
multidim_axis_data_width_{{ilh.id}}_{{ilh.dats[dat_id][0].ptr}}
    {%- else -%}
axis_data_width
    {%- endif -%}
{%- endmacro -%}
{% macro internal_stream_name(arg) -%}
arg{{ilh.getOrderedSwapPairIds(arg.dat_id)[0]}}_arg{{ilh.getOrderedSwapPairIds(arg.dat_id)[1]}}_streams
{%- endmacro -%}
{% block header_block %}

#pragma once
#include <ops_hls_kernel_support.h>
#include "common_config.hpp"
{% if config["datamover_mode"] == 2 %}
    {% for df_node in ilh.get_active_df_graph().getAllLoopNodes() %}
#include "PE_{{df_node.loop.kernel}}.hpp"
    {% endfor %}
{% endif %}

{% if ilh.isMultiDim() %}
    {% for dat, acc_type in ilh.dats %}
        {% if dat.isMultiDim() %}
constexpr unsigned short multidim_vector_factor_{{ilh.id}}_{{dat.ptr}} = vector_factor * {{dat.dim}};
constexpr unsigned short multidim_axis_data_width_{{ilh.id}}_{{dat.ptr}} = data_width * multidim_vector_factor_{{ilh.id}}_{{dat.ptr}};
        {% endif %}
    {% endfor %}
{% endif %}

{% endblock %}
{% block datamover_dataflow_region %}
{% endblock %}
{% block datamover_prototype %}
extern "C" void datamover_outerloop_{{ilh.id}}(
        const bool is_loopback,
    {% for i in range(ndim) %}
        const unsigned short range_start_{{i}},
        const unsigned short range_end_{{i}},
    {% endfor%}
    {% for i in range(ndim) %}
        const unsigned short gridSize_{{i}},
    {% endfor %}
        const unsigned int outer_itr,
    {% if config['datamover_mode'] == 2 %}
        const unsigned short stencilConfig_dim,
        {% for i in range(ndim)%}
        const unsigned short stencilConfig_lower_limit_{{i}},
        {% endfor %}
        {% for i in range(ndim)%}
        const unsigned short stencilConfig_upper_limit_{{i}},
        {% endfor %}
        const unsigned short stencilConfig_outer_loop_limit,
        {% for const_arg in ilh.joint_args|ops_gbl%}
        const {{const_arg.typ}} {{get_arg_gbl_name(const_arg)}},
        {% endfor %}
        {% for const in consts %}
        const {{const.typ}} {{const.ptr}},
        {% endfor %}
    {% endif %}
    {% for arg in ilh.joint_args|ops_dat %}
    //{{ilh.dats[arg.dat_id][0].ptr}}
        ap_uint<mem_data_width>* arg{{(arg.id)}}{{"," if (not loop.last or (config['SLR_count'] > 1 or config['datamover_mode'] == 1))}}
    {% endfor %}
    {% if config['SLR_count'] > 1 or config['datamover_mode'] == 1 %}
        {% for arg in ilh.joint_args|ops_dat %}
    //{{ilh.dats[arg.dat_id][0].ptr}}
            {% if (arg is not ops_rw) and arg is is_arg_swap(ilh) %}

        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name(arg)-}}{{"," if not loop.last}}
            {% else %}
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "out")-}},
        hls::stream <ap_axiu<{{axis_data_width(arg)-}},0,0,0>>& {{axis_name_t2(arg, "in")-}}{{"," if not loop.last}}
            {% endif %}
        {% endfor %}
    {% endif %}
    )
{% endblock %}
