{%- macro hls_stream_name(arg) -%}
    {%- if arg is not ops_rw -%}
arg{{arg.id}}_{{"rd" if (arg is ops_read) else ("wr" if (arg is ops_write))}}_buffer
    {%- endif -%}
{%- endmacro -%}

{%- macro hls_stream_name_t2(arg, suffix) -%}
arg{{arg.id}}_{{suffix}}_buffer
{%- endmacro -%}

{%- macro buffer_read_idx(buffer) -%}
    {%- if buffer.is_read_write_aligned -%}
{{buffer.name}}_rd_wr {%- else -%}{{buffer.name}}_rd {%- endif -%}
{%- endmacro -%}

{%- macro buffer_write_idx(buffer) -%}
    {%- if buffer.is_read_write_aligned -%}
{{buffer.name}}_rd_wr {%- else -%}{{buffer.name}}_wr {%- endif -%}
{%- endmacro -%}

{%- macro chainLinkTranform(link, arg, isread) -%}
    {%- if link is number -%}
arg{{arg.id}}_widenStencilValues[{{link}}]
    {%- elif link is window_buffer -%}
        {%- if isread -%}
arg{{arg.id}}_{{link.name}}[{{arg.stencil_ptr}}_{{buffer_read_idx(link)}}]
        {%- else -%}
arg{{arg.id}}_{{link.name}}[{{arg.stencil_ptr}}_{{buffer_write_idx(link)}}]
        {%- endif -%}
    {%- else -%}
arg{{arg.id}}_{{link}}
    {%- endif -%}
{%- endmacro -%}

{%- macro vector_factor_name(arg) -%}
vector_factor_{{lh.kernel}}_{{arg.id}}
{%- endmacro -%}

{%- macro axis_data_width_name(arg) -%}
axis_data_width_l_{{lh.kernel}}_{{arg.id}}
{%- endmacro -%}

{%- macro widen_dt_name(arg) -%}
widen_{{lh.kernel}}_{{arg.id}}_dt
{%- endmacro -%}

{%- macro widen_stream_dt_name(arg) -%}
widen_stream_{{lh.kernel}}_{{arg.id}}_dt
{%- endmacro -%}

{% set read_stencil = lh.get_read_stencil(prog) %}
{% set span_x = (read_stencil.stencil_size.x - 1) | int %}
{% set half_span_x = (span_x / 2) | int %}
{% set widen_span_x = (widen_read_stencil_desc.widen_stencil.stencil_size.x - 1) | int%}
{% set widen_half_span_x = (widen_span_x / 2) | int %}

{% block header_block %}
#pragma once
#include <ops_hls_kernel_support.h>
#include "common_config.hpp"

 
{% set widen_read_stencil = widen_read_stencil_desc.widen_stencil %}
{% if widen_read_stencil is not none %}
static constexpr unsigned short read_num_points_{{lh.kernel}} = {{widen_read_stencil.num_points}};
static constexpr unsigned short read_stencil_size_{{lh.kernel}} = {{widen_read_stencil.stencil_size.x}};
static constexpr unsigned short read_stencil_dim_{{lh.kernel}} = {{widen_read_stencil.dim}};
{% endif %}

static constexpr unsigned short write_num_points_{{lh.kernel}} = 1;
static constexpr unsigned short write_stencil_size_{{lh.kernel}} = 1;
static constexpr unsigned short write_stencil_dim_{{lh.kernel}} = {{lh.ndim}};

{% for arg in lh.args | ops_dat%}
static constexpr unsigned short {{vector_factor_name(arg)}} = vector_factor * {{lh.dats[arg.dat_id].dim}};
static constexpr unsigned short {{axis_data_width_name(arg)}} = {{vector_factor_name(arg)}} * data_width;
typedef ap_uint<{{axis_data_width_name(arg)}}> {{widen_dt_name(arg)}};
{% endfor %} 
{% for arg in lh.args | ops_dat%}
typedef ::hls::stream<{{widen_dt_name(arg)}}> {{widen_stream_dt_name(arg)}};
{% endfor %} 

{% endblock %}

{% block kernel_core %}
/*
{% for arg in lh.args %}
    {{arg}}
{% endfor %}
*/
inline void kernel_{{lh.kernel}}_core(
    {% for arg in lh.args %}
        {% if loop.last %}
            {% if consts %}
                {% set last_check = False %}
            {% else %}
                {% set last_check = True %}
            {% endif %}
        {% else %}
            {% set last_check = False %}
        {% endif %}
        {% if arg is ops_read %}
            {% if prog.findStencil(arg.stencil_ptr) %}
                {% for i in range(prog.findStencil(arg.stencil_ptr).num_points)%}
                    {% if lh.dats[arg.dat_id].isMultiDim() %}
                        {% for m_dim in range(lh.dats[arg.dat_id].dim) %}
        const stencil_type& reg_{{arg.id}}_{{i}}_{{m_dim}}{{"," if (not loop.last or not last_check)}}
                        {% endfor %}
                    {% else %}
        const stencil_type& reg_{{arg.id}}_{{i}}{{"," if (not loop.last or not last_check)}}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endif %}
        {% if arg is ops_write or arg is ops_rw%}
            {% if prog.findStencil(arg.stencil_ptr) %}
                {% for i in range(prog.findStencil(arg.stencil_ptr).num_points)%}
                    {% if lh.dats[arg.dat_id].isMultiDim() %}
                        {% for m_dim in range(lh.dats[arg.dat_id].dim) %}
        stencil_type& reg_{{arg.id}}_{{i}}_{{m_dim}}{{"," if (not loop.last or not last_check)}}
                        {% endfor %}
                    {% else %}
        stencil_type& reg_{{arg.id}}_{{i}}{{"," if (not loop.last or not last_check)}}
                    {% endif %}
                {% endfor %}
            {% else %}
        // ERROR: couldn't find stencil 
            {% endif %}
        {% endif %}
        {% if arg is ops_idx %}
        const short idx[3]{{"," if (not loop.last or not last_check)}}
        {% endif %}
        {% if arg is ops_gbl %}
        const {{arg.typ}}* {{kernel_args[loop.index0]}}{{"," if not loop.last}}
        {% endif %}
    {% endfor %}
    {% for const in consts %}
        const {{const.typ}}& {{const.ptr}}{{"," if not loop.last}}
    {% endfor %}
)
{
#ifdef DEBUG_LOG
    printf("[KERNEL_INTERNAL_CORE]|%s| starting kernel core: kernel_{{lh.kernel}}_core\n",__func__);
#endif
    {{kernel_body}}

#ifdef DEBUG_LOG
    {% for arg in lh.args %}
        {% if arg is ops_read %}
            {% if prog.findStencil(arg.stencil_ptr) %}
                {% for i in range(prog.findStencil(arg.stencil_ptr).num_points)%}
                    {% if lh.dats[arg.dat_id].isMultiDim() %}
                        {% for m_dim in range(lh.dats[arg.dat_id].dim) %}
    printf("[KERNEL_INTERNAL_CORE]|%s| read_val - reg_{{arg.id}}_{{i}}_{{m_dim}}: %f \n", __func__, reg_{{arg.id}}_{{i}}_{{m_dim}});
                        {% endfor %}
                    {% else %}
    printf("[KERNEL_INTERNAL_CORE]|%s| read_val - reg_{{arg.id}}_{{i}}: %f \n", __func__, reg_{{arg.id}}_{{i}});
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% elif arg is ops_write or arg is ops_rw%}
            {% if prog.findStencil(arg.stencil_ptr) %}
                {% for i in range(prog.findStencil(arg.stencil_ptr).num_points)%}
                    {% if lh.dats[arg.dat_id].isMultiDim() %}
                        {% for m_dim in range(lh.dats[arg.dat_id].dim) %}
    printf("[KERNEL_INTERNAL_CORE]|%s| write_val - reg_{{arg.id}}_{{i}}_{{m_dim}}: %f \n", __func__, reg_{{arg.id}}_{{i}}_{{m_dim}});
                        {% endfor %}
                    {% else %}
    printf("[KERNEL_INTERNAL_CORE]|%s| write_val - reg_{{arg.id}}_{{i}}: %f \n", __func__, reg_{{arg.id}}_{{i}});
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% elif arg is ops_idx %}
    printf("[KERNEL_INTERNAL_CORE]|%s| index_val: (%d, %d, %d) \n", __func__, idx[0], idx[1], idx[2]);
        {% endif %}
    {% endfor %}
#endif

#ifdef DEBUG_LOG
    printf("[KERNEL_INTERNAL_CORE]|%s| exiting: kernel_{{lh.kernel}}_core\n",__func__);
#endif
}
{% endblock %}

{% block stencil_class %}
class Stencil_{{lh.kernel}} : public ops::hls::StencilCoreV2<stencil_type, read_num_points_{{lh.kernel}}, vector_factor, ops::hls::CoefTypes::CONST_COEF,
        read_stencil_size_{{lh.kernel}}, read_stencil_dim_{{lh.kernel}}>
{
    using ops::hls::StencilCoreV2<stencil_type, read_num_points_{{lh.kernel}}, vector_factor, ops::hls::CoefTypes::CONST_COEF,
            read_stencil_size_{{lh.kernel}}, read_stencil_dim_{{lh.kernel}}>::m_stencilConfig;
public:

    void stencilRun(
    {% for arg in lh.args|ops_not_idx %}
        {% if loop.last %}
            {% if consts %}
                {% set last_check = False %}
            {% else %}
                {% set last_check = True %}
            {% endif %}
        {% else %}
            {% set last_check = False %}
        {% endif %}
        {% if arg is ops_dat %}
            {% if (arg is ops_read) %}
            {{widen_stream_dt_name(arg)}}& {{hls_stream_name(arg)-}}{{"," if (not loop.last or not last_check)}}
            {% elif arg is ops_write %}
            {{widen_stream_dt_name(arg)}}& {{hls_stream_name(arg)-}}{{"," if (not loop.last or not last_check)}}
            {% else %}
            {{widen_stream_dt_name(arg)}}& {{hls_stream_name_t2(arg, "rd")-}},
            {{widen_stream_dt_name(arg)}}& {{hls_stream_name_t2(arg, "wr")-}}{{"," if (not loop.last or not last_check)}}
            {% endif %}
        {% elif arg is ops_gbl %}
            const {{arg.typ}}& {{get_arg_gbl_name(arg)}}{{"," if (not loop.last or not last_check)}}
        {% endif %}
    {% endfor %}
    {% for const in consts %}
            const {{const.typ}}& {{const.ptr}}{{"," if not loop.last}}
    {% endfor %}
        )
    {
        const unsigned short span_x = {{span_x}};
        const unsigned short half_span_x = {{half_span_x}};

        ::ops::hls::StencilConfigCore stencilConfig = m_stencilConfig;
    {% set read_origin_wide_diff = read_stencil.read_origin_diff %}
    {% set read_origin_wide_diff_x = read_origin_wide_diff.x %}
    {% set read_origin_wide_diff_x  = ((read_origin_wide_diff_x + config["vector_factor"] - 1) / config["vector_factor"])|round(0,"floor")|int %}
    //read_origin_wide_diff_x: {{read_origin_wide_diff_x}}, read_origin_wide_diff: {{read_origin_wide_diff}}
    
    //  *** counters definitions ****
    {% if lh.ndim == 1 %}
        short i = {{(-read_origin_wide_diff_x) - 1}};
    {% elif lh.ndim == 2 %}
        short i = {{ (-read_origin_wide_diff_x) - 1}};
        short j = -{{read_origin_wide_diff.y}}; 
    {% elif lh.ndim == 3 %}
        short i = {{ (-read_origin_wide_diff_x) - 1}};
        short j = {{(-read_origin_wide_diff.y)}}; 
        short k = {{(-read_origin_wide_diff.z)}};
        unsigned short plane_diff = stencilConfig.grid_size[0] * stencilConfig.grid_size[1] - 1;
    {% endif %}

    //  *** stencil description and read & write point definitions  ****
        /*
        {{widen_read_stencil_desc}}
        */
    {% for stencil_name in lh.get_unique_read_stencil_names() %}
        // Stencil: {{stencil_name}}
        {% for point  in prog.findStencil(stencil_name).points %}
        //      {{"|-" if not loop.last else "`-"}} point: {{point}}
        {% endfor %}
        {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
            {% if buffer.buffer_type == ops.BufferType.LINE_BUFF %}
        // read point: {{buffer.read_point}}, write point: {{buffer.write_point}}
                {% if buffer.is_read_write_aligned %}
        unsigned short {{stencil_name}}_{{buffer_read_idx(buffer)}} = 0;
                {% else %}
        unsigned short {{stencil_name}}_{{buffer_read_idx(buffer)}} = {{(buffer.read_point.x - buffer.write_point.x, 0)|max}};
        unsigned short {{stencil_name}}_{{buffer_write_idx(buffer)}} = {{(buffer.write_point.x - buffer.read_point.x, 0)|max}};
                {% endif %}
            {% else %}
                {% if buffer.is_read_write_aligned %}
        unsigned short {{stencil_name}}_{{buffer_read_idx(buffer)}} = 0;
                {% else %}
        unsigned short {{stencil_name}}_{{buffer_read_idx(buffer)}};
        
        if ({{(buffer.read_point - buffer.write_point).y}} * stencilConfig.grid_size[0] + {{(buffer.read_point - buffer.write_point).x}} > 0)
            {{stencil_name}}_{{buffer_read_idx(buffer)}} = {{(buffer.read_point - buffer.write_point).y}} * stencilConfig.grid_size[0] + {{(buffer.read_point - buffer.write_point).x}};
        else
            {{stencil_name}}_{{buffer_read_idx(buffer)}} = 0;

        unsigned short {{stencil_name}}_{{buffer_write_idx(buffer)}};
        
        if ({{(buffer.write_point - buffer.read_point).y}} * stencilConfig.grid_size[0] + {{(buffer.write_point - buffer.read_point).x}} > 0)
            {{stencil_name}}_{{buffer_write_idx(buffer)}} = {{(buffer.write_point - buffer.read_point).y}} * stencilConfig.grid_size[0] + {{(buffer.write_point - buffer.read_point).x}};
        else
            {{stencil_name}}_{{buffer_write_idx(buffer)}} = 0;
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endfor %}

        #pragma HLS ARRAY_PARTITION variable = stencilConfig.lower_limit dim = 1 complete
        #pragma HLS ARRAY_PARTITION variable = stencilConfig.upper_limit dim = 1 complete

    //  *** iteration limit definition ****
    {% if lh.ndim  == 1 %}
        unsigned int iter_limit = stencilConfig.outer_loop_limit;
    {% elif lh.ndim == 2%}
        unsigned int iter_limit = stencilConfig.outer_loop_limit * stencilConfig.grid_size[0]{%- if read_origin_wide_diff_x != 0 %} + {{read_origin_wide_diff_x}}{%- endif %};
    {% else %}
        unsigned int iter_limit = stencilConfig.outer_loop_limit * 
                stencilConfig.grid_size[1] * stencilConfig.grid_size[0] {% if read_origin_wide_diff[1] !=0 -%} + {{read_origin_wide_diff[1]}} * stencilConfig.grid_size[0] {%- endif %} {%- if read_origin_wide_diff_x != 0 %} + {{read_origin_wide_diff_x}}{%- endif %};
    {% endif %}

    //  *** data read write boundary definitions ****
    {% for arg in lh.args|ops_dat|ops_read_or_rw %}
        {% if lh.ndim == 1 %}
            {% set base_offset = widen_read_stencil_desc.widen_stencil.base_point.x - widen_stencil_disc_map[arg.stencil_ptr].widen_stencil.base_point.x %}
        unsigned int arg{{arg.id}}_read_lb_itr = {{base_offset}};
        unsigned int arg{{arg.id}}_read_ub_itr = {{base_offset}} + stencilConfig.grid_size[0];
        {% elif lh.ndim == 2 %}
            {% set base_offset = widen_read_stencil_desc.widen_stencil.base_point.y - widen_stencil_disc_map[arg.stencil_ptr].widen_stencil.base_point.y %}
        unsigned int arg{{arg.id}}_read_lb_itr = {{base_offset}} * stencilConfig.grid_size[0];
        unsigned int arg{{arg.id}}_read_ub_itr = ({{base_offset}} + stencilConfig.grid_size[1]) * stencilConfig.grid_size[0];
        {% else %}
            {% set base_offset = widen_read_stencil_desc.widen_stencil.base_point.z - widen_stencil_disc_map[arg.stencil_ptr].widen_stencil.base_point.z %}
        unsigned int arg{{arg.id}}_read_lb_itr = {{base_offset}} * stencilConfig.grid_size[0] * stencilConfig.grid_size[1];
        unsigned int arg{{arg.id}}_read_ub_itr = ({{base_offset}} + stencilConfig.grid_size[2]) * stencilConfig.grid_size[1] * stencilConfig.grid_size[0];
        {% endif %}
    {% endfor %}

    //  *** Read & write widen temporaries ****
    {% for arg in lh.args|ops_dat %}
    // arg{{arg.id}}({{lh.dats[arg.dat_id].ptr}})
        {% if arg is ops_read %}
        {{widen_dt_name(arg)}} arg{{arg.id}}_read_val = 0;
        {% elif arg is ops_write %}
        {{widen_dt_name(arg)}} arg{{arg.id}}_update_val;
        {% else %}
        {{widen_dt_name(arg)}} arg{{arg.id}}_read_val = 0;
        {{widen_dt_name(arg)}} arg{{arg.id}}_update_val;
        {% endif %}
    {% endfor %}

    //  *** widen stencil values holder & window buffers ****
    {% for arg in lh.args|ops_dat|ops_read_or_rw %}

        // arg{{arg.id}}({{lh.dats[arg.dat_id].ptr}})
        {{widen_dt_name(arg)}} arg{{arg.id}}_widenStencilValues[read_num_points_{{lh.kernel}}];
        #pragma HLS ARRAY_PARTITION variable = arg{{arg.id}}_widenStencilValues dim = 1 complete

        {% for buffer in widen_stencil_disc_map[arg.stencil_ptr].window_buffers %}
            {% if buffer.buffer_type == ops.BufferType.LINE_BUFF and lh.ndim == 3 %}
        {{widen_dt_name(arg)}} arg{{arg.id}}_{{buffer.name}}[line_buff_3d_depth];
            {% else %}
        {{widen_dt_name(arg)}} arg{{arg.id}}_{{buffer.name}}[max_depth];
            {% endif %}
            {% if buffer.is_read_write_aligned %}
        #pragma HLS BIND_STORAGE variable = arg{{arg.id}}_{{buffer.name}} type = ram_s2p latency=2
            {% else %}
        #pragma HLS BIND_STORAGE variable = arg{{arg.id}}_{{buffer.name}} type = ram_t2p latency=2
            {% endif %}
        {% endfor %}

        {% for row_discriptor in prog.findStencil(arg.stencil_ptr).row_discriptors %}
            {% if lh.dats[arg.dat_id].isMultiDim() %}
                {% for m_dim in range(lh.dats[arg.dat_id].dim) %}
        stencil_type arg{{arg.id}}_{{m_dim}}_rowArr_{{row_discriptor.row_id[0]}}_{{row_discriptor.row_id[1]}}[vector_factor + span_x];
        #pragma HLS ARRAY_PARTITION variable = arg{{arg.id}}_{{m_dim}}_rowArr_{{row_discriptor.row_id[0]}}_{{row_discriptor.row_id[1]}} dim=1 complete
                {% endfor %}
            {% else %}
        stencil_type arg{{arg.id}}_rowArr_{{row_discriptor.row_id[0]}}_{{row_discriptor.row_id[1]}}[vector_factor + span_x];
        #pragma HLS ARRAY_PARTITION variable = arg{{arg.id}}_rowArr_{{row_discriptor.row_id[0]}}_{{row_discriptor.row_id[1]}} dim=1 complete
            {% endif %}
        {% endfor %}
    {% endfor %}

        const short cond_x_val = stencilConfig.grid_size[0] - 1; 
    {% if lh.ndim == 2 %}
        const short cond_y_val = stencilConfig.outer_loop_limit - 1;
    {% elif lh.ndim == 3 %}
        const short cond_y_val = stencilConfig.grid_size[1] - 1;
        const short cond_z_val = stencilConfig.outer_loop_limit - 1;
    {% endif %}

        for (unsigned int itr = 0; itr < iter_limit; itr++)
        {
        #pragma HLS PIPELINE II=1

            spc_temp_blocking_read:
            {
                bool cond_x_terminate = (i == cond_x_val ? true : false); 
    {% if lh.ndim == 2 %}
                bool cond_y_terminate = (j == cond_y_val ? true : false);
    {% elif lh.ndim == 3 %}
                bool cond_y_terminate = (j == cond_y_val ? true : false);
                bool cond_z_terminate = (k == cond_z_val ? true : false);
    {% endif %}

#ifdef DEBUG_LOG
                printf("[DEBUG][INTERNAL][{{lh.kernel}}_PE_%d] loop params before update i(%d), "\
    {% if lh.ndim > 1 %}
                    "j(%d), "\
    {% endif %}
    {% if lh.ndim > 2 %}
                    "k(%d), "\
    {% endif %}
    {% for stencil_name in lh.get_unique_read_stencil_names() %}
        {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
                    "{{stencil_name}}_{{buffer_read_idx(buffer)}}: %d, "\
                    "{{stencil_name}}_{{buffer_write_idx(buffer)}}: %d, "\
        {% endfor %}
    {% endfor %}
                    "itr(%d)\n", m_PEId, i, 
    {% if lh.ndim > 1 %}
                    j,
    {% endif %}
    {% if lh.ndim > 2 %}
                    k,
    {% endif %}
    {% for stencil_name in lh.get_unique_read_stencil_names() %}
        {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
                    {{stencil_name}}_{{buffer_read_idx(buffer)}}, 
                    {{stencil_name}}_{{buffer_write_idx(buffer)}}, 
        {% endfor %}
    {% endfor %}
                    itr);
#endif
                if (cond_x_terminate)
                    i = 0;
                else
                    i++;
    {% if lh.ndim > 1 %}
                if (cond_x_terminate && cond_y_terminate)
                    j = 0;
                else if  (cond_x_terminate)
                    j++;
    {% endif %}
    {% if lh.ndim > 2%}
                if (cond_x_terminate && cond_y_terminate && cond_z_terminate)
                    k = 0;
                else if (cond_x_terminate && cond_y_terminate)
                    k++;
    {% endif %}

    {% for arg in lh.args|ops_dat|ops_read_or_rw %}
                bool arg{{arg.id}}_read_cond = (itr < arg{{arg.id}}_read_ub_itr) and (itr >= arg{{arg.id}}_read_lb_itr);
    {% endfor %}

    {% for arg in lh.args|ops_dat|ops_read_or_rw %}
                if (arg{{arg.id}}_read_cond)
                    arg{{arg.id}}_read_val = arg{{arg.id}}_rd_buffer.read();
    {% endfor %}
                
    {% for arg in lh.args|ops_dat|ops_read_or_rw %}
        {% for chain in widen_stencil_disc_map[arg.stencil_ptr].chains %}                
                {{chainLinkTranform(chain[0], arg, 1)}} = {{chainLinkTranform(chain[1], arg, 0)}};{% endfor %}
    {% endfor %}


    {% for stencil_name in lh.get_unique_read_stencil_names() %}
        {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
            {% if buffer.buffer_type == ops.BufferType.LINE_BUFF %}
                bool cond_end_of_line_buff_{{stencil_name}}_{{buffer_read_idx(buffer)}} = {{stencil_name}}_{{buffer_read_idx(buffer)}} >= (stencilConfig.grid_size[0] - 1);
                {% if not buffer.is_read_write_aligned %}
                bool cond_end_of_line_buff_{{stencil_name}}_{{buffer_write_idx(buffer)}} = {{stencil_name}}_{{buffer_write_idx(buffer)}} >= (stencilConfig.grid_size[0] - 1);
                {% endif %}
            {% else %}
                bool cond_end_of_line_buff_{{stencil_name}}_{{buffer_read_idx(buffer)}} = {{stencil_name}}_{{buffer_read_idx(buffer)}} >= (plane_diff);
                {% if not buffer.is_read_write_aligned %}
                bool cond_end_of_line_buff_{{stencil_name}}_{{buffer_write_idx(buffer)}} = {{stencil_name}}_{{buffer_write_idx(buffer)}} >= (plane_diff);
                {% endif %}
            {% endif %}

                if (cond_end_of_line_buff_{{stencil_name}}_{{buffer_read_idx(buffer)}})
                    {{stencil_name}}_{{buffer_read_idx(buffer)}} = 0;
                else
                    {{stencil_name}}_{{buffer_read_idx(buffer)}}++;
            {% if not buffer.is_read_write_aligned %}

                if (cond_end_of_line_buff_{{stencil_name}}_{{buffer_write_idx(buffer)}})
                    {{stencil_name}}_{{buffer_write_idx(buffer)}} = 0;
                else
                    {{stencil_name}}_{{buffer_write_idx(buffer)}}++;
            {% endif %}
        {% endfor %}
    {% endfor %}

#ifdef DEBUG_LOG
                printf("[DEBUG][INTERNAL][{{lh.kernel}}_PE_%d] loop params after update i(%d), "\
                {% if lh.ndim > 1 %}
                                "j(%d), "\
                {% endif %}
                {% if lh.ndim > 2 %}
                                "k(%d), "\
                {% endif %}
                {% for stencil_name in lh.get_unique_read_stencil_names() %}
                    {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
                                "{{stencil_name}}_{{buffer_read_idx(buffer)}}(%d), "\
                                "{{stencil_name}}_{{buffer_write_idx(buffer)}}(%d), "\
                    {% endfor %}
                {% endfor %}
                                "itr(%d)\n", m_PEId, i, 
                {% if lh.ndim > 1 %}
                                j,
                {% endif %}
                {% if lh.ndim > 2 %}
                                k,
                {% endif %}
                {% for stencil_name in lh.get_unique_read_stencil_names() %}
                    {% for buffer in widen_stencil_disc_map[stencil_name].window_buffers %}
                                {{stencil_name}}_{{buffer_read_idx(buffer)}}, 
                                {{stencil_name}}_{{buffer_write_idx(buffer)}}, 
                    {% endfor %}
                {% endfor %}
                                itr);
            
                printf("[DEBUG][INTERNAL][{{lh.kernel}}_PE_%d] --------------------------------------------------------\n\n", m_PEId);

    {% for arg in lh.args|ops_dat|ops_read_or_rw %}
