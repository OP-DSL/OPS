    {% set base_offset = read_stencil.base_point.x - prog.findStencil(arg.stencil_ptr).base_point.x %}
            {#{{get_read_arg_from_dat(lh.dats[datMap[arg.dat_id]], lh)}}#}
            //dat_id: {{arg.dat_id}}, dat: {{lh.dats[arg.dat_id].ptr}}, swap_id: {{datMap[arg.dat_id]}}, swap_dat: {{lh.dats[datMap[arg.dat_id]].ptr}}
            {% if get_read_arg_from_dat(lh.dats[datMap[arg.dat_id]], lh) %}
