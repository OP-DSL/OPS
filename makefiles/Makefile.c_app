cleanall: clean
	rm -rf ./mpi_openmp ./cuda ./hip ./openmp_offload ./sycl
	
clean:
	rm -f *.o
	rm -f *.oo
	rm -f *.optrpt
	rm -f *~
	rm -f *.lst
	rm -f $(APP)_dev_seq
	rm -f $(APP)_dev_mpi
	rm -f $(APP)_seq
	rm -f $(APP)_tiled
	rm -f $(APP)_openmp
	rm -f $(APP)_mpi
	rm -f $(APP)_mpi_tiled
	rm -f $(APP)_mpi_openmp
	rm -f $(APP)_cuda
	rm -f $(APP)_mpi_cuda
	rm -f $(APP)_mpi_cuda_tiled
	rm -f $(APP)_hip
	rm -f $(APP)_mpi_hip
	rm -f $(APP)_mpi_hip_tiled
#	rm -f $(APP)_openacc
#	rm -f $(APP)_mpi_openacc
#	rm -f $(APP)_mpi_openacc_tiled
	rm -f $(APP)_ompoffload
	rm -f $(APP)_mpi_ompoffload
	rm -f $(APP)_mpi_ompoffload_tiled
	rm -f $(APP)_sycl
	rm -f $(APP)_mpi_sycl
	rm -f $(APP)_mpi_sycl_tiled
	rm -f $(APP)_openacc
	rm -f $(APP)_mpi_openacc
	rm -f $(APP)_mpi_openacc_tiled
	rm -f $(OPS_GENERATED)
	rm -f .generated constants_list.txt cudafe .generated_hls
	rm -rf ./mpi_openmp ./cuda ./hip ./openmp_offload ./sycl ./openacc ./hls
	rm -f *_ops_hls.cpp
	rm -rf _x .Xil xcd.log
	rm -f ops_translator_run.log source_pp.txt
	rm -f xrc.log
	rm -f *_ast.txt  
	rm -f *.png
	rm -f *.dot
