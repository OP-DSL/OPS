
ifndef OPS_GENERATED_SUFFIX
OPS_GENERATED_SUFFIX=_ops
endif

ifeq ($(strip $(OPS_GENERATED)),)
OPS_GENERATED=$(join $(addsuffix $(OPS_GENERATED_SUFFIX), $(basename $(OPS_FILES))), $(suffix $(OPS_FILES)))
endif

OPS_FILES_PLAIN=$(OPS_FILES) $(OTHER_FILES)
OPS_FILES_GEN=$(OTHER_FILES) $(OPS_GENERATED)

ifndef APP
$(error APP is not set)
endif

ifndef MAIN_SRC
$(error MAIN_SRC is not set)
endif

VERBOSE=

ifdef OPS_GENERATOR_VERBOSE
	VERBOSE=-v
endif

DEFINES=-DOPS_ACC_IGNORE

.generated: $(OPS_FILES) $(OPS_INSTALL_PATH)/../ops_translator/ops-translator/*.py
	@echo "generating translations for ${OPS_FILES}"
	@echo "OPS_EXTENTIONS: ${OPS_GENERATED_SUFFIX}"
	@echo "OPS_GENERATED: ${OPS_GENERATED}"
	which python3
	python3 $(OPS_INSTALL_PATH)/../ops_translator/ops-translator $(VERBOSE) $(DEFINES) -I $(OPS_INSTALL_PATH)/c/include/ --file_paths $(OPS_FILES)
	rm -f .generated
	touch .generated

# check what targets can not be built with current environment setting and give warnings
ifneq ($(strip $(TARGETS)),)

ifneq (,$(filter cuda mpi_cuda mpi_cuda_tiled,$(TARGETS)))
ifneq ($(OPS_COMPILER),pgi)
TARGETS:=$(filter-out cuda mpi_cuda mpi_cuda_tiled,$(TARGETS))
#$(info CUDA targets cannot be built with current environment settings....)
#$(info Build continues without CUDA targets.....)
endif	#ifneq OMP_COMPILER=PGI
endif

ifneq (,$(filter f2c_cuda f2c_mpi_cuda f2c_mpi_cuda_tiled,$(TARGETS)))
ifndef CUDA_INSTALL_PATH
TARGETS:=$(filter-out f2c_cuda f2c_mpi_cuda f2c_mpi_cuda_tiled,$(TARGETS))
endif	#ifndef CUDA_INSTALL_PATH
endif

ifneq (,$(filter f2c_hip f2c_mpi_hip f2c_mpi_hip_tiled,$(TARGETS)))
ifndef HIP_INSTALL_PATH
TARGETS:=$(filter-out f2c_hip f2c_mpi_hip f2c_mpi_hip_tiled,$(TARGETS))
#$(info HIP targets cannot be built with current environment settings....)
#$(info Please set the HIP_INSTALL_PATH and relevant environment variables (e.g., PATH, LD_LIBRARY_PATH).)
#$(info Build continues without HIP targets.....)
endif
endif

endif	#ifneq TARGETS

ifndef TARGETS
TARGETS	= seq tiled openmp mpi mpi_openmp mpi_tiled ompoffload mpi_ompoffload mpi_ompoffload_tiled f2c_seq f2c_mpi f2c_mpi_tiled

ifeq ($(OPS_COMPILER),pgi)
TARGETS += cuda mpi_cuda mpi_cuda_tiled
endif

ifdef CUDA_INSTALL_PATH
TARGETS += f2c_cuda f2c_mpi_cuda f2c_mpi_cuda_tiled
endif

ifdef HIP_INSTALL_PATH
TARGETS += f2c_hip f2c_mpi_hip f2c_mpi_hip_tiled
endif

ifdef SYCL_INSTALL_PATH
TARGETS += f2c_sycl
endif

ifeq ($(OPS_COMPILER),xlp8)
TARGETS += poisson_mpi_cuda
endif

endif	#ifndef TARGETS

ifneq (,$(filter ompoffload mpi_ompoffload mpi_ompoffload_tiled,$(TARGETS)))
OTHER_FILES_OFFLOAD := $(patsubst %, %_offload, $(filter-out constants.F90, $(OTHER_FILES))) constants_offload.F90
endif

ifneq (,$(filter ompoffload mpi_ompoffload mpi_ompoffload_tiled,$(TARGETS)))
ifeq ($(OPS_COMPILER),gnu)
TARGETS:=$(filter-out ompoffload mpi_ompoffload mpi_ompoffload_tiled,$(TARGETS))
endif
ifeq ($(OPS_COMPILER),intel)
TARGETS:=$(filter-out ompoffload mpi_ompoffload mpi_ompoffload_tiled,$(TARGETS))
endif
ifeq ($(OPS_COMPILER),intel-sycl)
TARGETS:=$(filter-out ompoffload mpi_ompoffload mpi_ompoffload_tiled,$(TARGETS))
endif
endif

ifneq (,$(filter f2c_sycl f2c_mpi_sycl f2c_mpi_sycl_tiled,$(TARGETS)))
ifndef SYCL_INSTALL_PATH
TARGETS:=$(filter-out f2c_sycl f2c_mpi_sycl f2c_mpi_sycl_tiled,$(TARGETS))
endif
endif

ifneq ($(strip $(MPI_INSTALL_PATH)),)
ifneq (,$(wildcard $(MPI_INC)))
I_MPI_INC = -I$(MPI_INC)
endif
ifneq (,$(wildcard $(MPI_LIB)))
L_MPI_LIB = -L$(MPI_LIB)
endif
else
I_MPI_INC = $(foreach dir,$(shell $(MPICC) --showme:incdirs),-I$(dir))
endif

F2C_CXXFLAGS = $(CXXFLAGS)
ifeq ($(filter $(OPS_COMPILER),intel pgi),$(OPS_COMPILER))
F2C_CXXFLAGS := $(subst -std=c++11,-std=c++14,$(F2C_CXXFLAGS))
endif

F2C_NVCCFLAGS = $(NVCCFLAGS)
ifneq ($(strip $(F2C_NVCCFLAGS)),)
F2C_NVCCFLAGS := $(subst -std=c++11,-std=c++14,$(F2C_NVCCFLAGS))
F2C_NVCCFLAGS += --expt-relaxed-constexpr
endif

F2C_HIPFLAGS = $(HIPFLAGS)
ifneq ($(strip $(F2C_HIPFLAGS)),)
F2C_HIPFLAGS := $(subst -std=c++11,-std=c++14,$(F2C_HIPFLAGS))
#F2C_HIPFLAGS += --expt-relaxed-constexpr
endif

CXXFLAGS_NOOMP = $(CXXFLAGS)
CXXFLAGS_NOOMP := $(filter-out -fopenmp, $(CXXFLAGS_NOOMP))
CXXFLAGS_NOOMP := $(filter-out -qopenmp, $(CXXFLAGS_NOOMP))

F2C_CUDAFOR = $(CUDAFOR)
ifeq ($(OPS_COMPILER),pgi)
F2C_CUDAFOR := $(filter-out -DOPS_WITH_CUDAFOR, $(F2C_CUDAFOR))
endif

APP_TARGETS = $(addprefix $(APP)_, $(TARGETS))

all: $(APP_TARGETS)

#=====================================================================================================================================================================
#
# Sequential version
#

$(APP)_seq: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_seq.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_seq"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_seq $(F_HDF5_LIB_SEQ) -o $(APP)_seq

#=====================================================================================================================================================================
#
# F2C Sequential version
#

F2C_KERNEL_FILES = $(wildcard f2c_mpi_openmp/*.F90)
F2C_KERNEL_OBJS = $(F2C_KERNEL_FILES:.F90=_f2c_seq.o)

# C++ Master kernel file
F2C_CXX_SRC = f2c_mpi_openmp/f2c_mpi_openmp_kernels.cpp
F2C_CXX_OBJS = $(F2C_CXX_SRC:.cpp=_f2c_seq.o)

# Other Fortran files and generated files
F2C_OTHER_OBJS = $(OTHER_FILES:.F90=_f2c_seq.o)
F2C_OPS_GEN_OBJS = $(OPS_GENERATED:.F90=_f2c_seq.o)

$(F2C_CXX_OBJS): $(F2C_CXX_SRC)
	$(MPICPP) $(F2C_CXXFLAGS) -DOPS_FTN -I$(C_OPS_INC) -I. -c $< -o $@

# Final target
$(APP)_f2c_seq: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_f2c_seq.a $(OPS_FILES_GEN) $(F2C_CXX_OBJS)
		@echo ""
		@echo ""
		@echo "Building ${APP}_f2c_seq"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_seq.o);)
		$(foreach src, $(F2C_KERNEL_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_seq.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_seq.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) -I$(C_OPS_INC) $(FMODS) $(F2C_CXX_OBJS) $(F2C_OTHER_OBJS) $(F2C_KERNEL_OBJS) $(F2C_OPS_GEN_OBJS) $(APP_LIBS) $(FLINK) -lops_f2c_seq $(F_HDF5_LIB_SEQ) -o $(APP)_f2c_seq

#=====================================================================================================================================================================
#
# mpi version
#

$(APP)_mpi: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_mpi.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_mpi"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI $(I_MPI_INC) $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_mpi $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_mpi

#=====================================================================================================================================================================
#
# F2C mpi version
#

F2C_KERNEL_FILES = $(wildcard f2c_mpi_openmp/*.F90)
MPI_F2C_KERNEL_OBJS = $(F2C_KERNEL_FILES:.F90=_f2c_mpi.o)

F2C_CXX_SRC = f2c_mpi_openmp/f2c_mpi_openmp_kernels.cpp
MPI_F2C_CXX_OBJS = $(F2C_CXX_SRC:.cpp=_f2c_mpi.o)

MPI_F2C_OTHER_OBJS = $(OTHER_FILES:.F90=_f2c_mpi.o)
MPI_F2C_OPS_GEN_OBJS = $(OPS_GENERATED:.F90=_f2c_mpi.o)

$(MPI_F2C_CXX_OBJS): $(F2C_CXX_SRC)
	$(MPICPP) $(F2C_CXXFLAGS) -DOPS_FTN -DOPS_MPI $(I_MPI_INC) -I$(C_OPS_INC) -I. -c $< -o $@

$(APP)_f2c_mpi: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_f2c_mpi.a $(OPS_FILES_GEN) $(MPI_F2C_CXX_OBJS)
		@echo ""
		@echo ""
		@echo "Building ${APP}_f2c_mpi"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi.o);)
		$(foreach src, $(F2C_KERNEL_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) -DOPS_MPI -I$(C_OPS_INC) $(FMODS) $(I_MPI_INC) $(MPI_F2C_CXX_OBJS) $(MPI_F2C_OTHER_OBJS) $(MPI_F2C_KERNEL_OBJS) $(MPI_F2C_OPS_GEN_OBJS) $(APP_LIBS) $(FLINK) -lops_f2c_mpi $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_f2c_mpi

#=====================================================================================================================================================================
#
# OpenMP version
#

$(APP)_openmp: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_seq.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_openmp"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) $(OMPFLAGS) $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_seq $(F_HDF5_LIB_SEQ) -o $(APP)_openmp

$(APP)_mpi_openmp: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_mpi.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_mpi_openmp"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) $(OMPFLAGS) -DOPS_MPI $(I_MPI_INC) $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_mpi $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_mpi_openmp

#=====================================================================================================================================================================
#
# Tiled version
#

$(APP)_tiled: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_seq.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_tiled"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_LAZY $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_seq $(F_HDF5_LIB_SEQ) -o $(APP)_tiled

$(APP)_mpi_tiled: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_mpi.a $(OPS_FILES_GEN)
		@echo ""
		@echo ""
		@echo "Building ${APP}_mpi_tiled"
		@echo ""
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_LAZY $(I_MPI_INC) $(OTHER_FILES) mpi_openmp/*_seq_kernel.F90 $(OPS_GENERATED) $(APP_LIBS) $(FLINK) -lops_for_mpi $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_mpi_tiled

#=====================================================================================================================================================================
#
# F2C mpi tiled version
#

F2C_KERNEL_FILES = $(wildcard f2c_mpi_openmp/*.F90)
MPI_TILED_F2C_KERNEL_OBJS = $(F2C_KERNEL_FILES:.F90=_f2c_mpi_tiled.o)

F2C_CXX_SRC = f2c_mpi_openmp/f2c_mpi_openmp_kernels.cpp
MPI_TILED_F2C_CXX_OBJS = $(F2C_CXX_SRC:.cpp=_f2c_mpi_tiled.o)

MPI_TILED_F2C_OTHER_OBJS = $(OTHER_FILES:.F90=_f2c_mpi_tiled.o)
MPI_TILED_F2C_OPS_GEN_OBJS = $(OPS_GENERATED:.F90=_f2c_mpi_tiled.o)

$(MPI_TILED_F2C_CXX_OBJS): $(F2C_CXX_SRC)
	$(MPICPP) $(F2C_CXXFLAGS) -DOPS_FTN -DOPS_MPI -DOPS_LAZY $(I_MPI_INC) -I$(C_OPS_INC) -I. -c $< -o $@

$(APP)_f2c_mpi_tiled: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_f2c_mpi.a $(OPS_FILES_GEN) $(MPI_TILED_F2C_CXX_OBJS)
		@echo ""
		@echo ""
		@echo "Building ${APP}_f2c_mpi_tiled"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_tiled.o);)
		$(foreach src, $(F2C_KERNEL_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_tiled.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_tiled.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) -DOPS_MPI -DOPS_LAZY -I$(C_OPS_INC) $(FMODS) $(I_MPI_INC) $(MPI_TILED_F2C_CXX_OBJS) $(MPI_TILED_F2C_OTHER_OBJS) $(MPI_TILED_F2C_KERNEL_OBJS) $(MPI_TILED_F2C_OPS_GEN_OBJS) $(APP_LIBS) $(FLINK) -lops_f2c_mpi $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_f2c_mpi_tiled

#=====================================================================================================================================================================
#
# CUDA version
#
CUDA_KERNELS = $(wildcard cuda/*.CUF)

OTHER_CUDA_OBJ = $(OTHER_FILES:.F90=_cuda.o)
CUDA_KERNELS_OBJ = $(CUDA_KERNELS:.CUF=_cuda.o)
CUDA_OPS_GENERATED_OBJ = $(OPS_GENERATED:.F90=_cuda.o)

OTHER_MPI_CUDA_OBJ = $(OTHER_FILES:.F90=_mpi_cuda.o)
MPI_CUDA_KERNELS_OBJ = $(CUDA_KERNELS:.CUF=_mpi_cuda.o)
MPI_CUDA_OPS_GENERATED_OBJ = $(OPS_GENERATED:.F90=_mpi_cuda.o)

OTHER_MPI_CUDA_TILED_OBJ = $(OTHER_FILES:.F90=_mpi_cuda_tiled.o)
MPI_CUDA_TILED_KERNELS_OBJ = $(CUDA_KERNELS:.CUF=_mpi_cuda_tiled.o)
MPI_CUDA_TILED_OPS_GENERATED_OBJ = $(OPS_GENERATED:.F90=_mpi_cuda_tiled.o)


$(APP)_cuda: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_cuda.a $(OPS_FILES_GEN) $(CUDA_OBJ)
		@echo ""
		@echo ""
		@echo "Building ${APP}_cuda"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) $(FMODS_CUDA) -c $(src) -o $(src:.F90=_cuda.o);)
		$(foreach src, $(CUDA_KERNELS), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) $(FMODS_CUDA) -c $(src) -o $(src:.CUF=_cuda.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) $(FMODS_CUDA) -c $(src) -o $(src:.F90=_cuda.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_CUDA) $(CUDAFOR) $(OTHER_CUDA_OBJ) $(CUDA_KERNELS_OBJ) $(CUDA_OPS_GENERATED_OBJ) $(APP_LIBS) $(FLINK) -lops_for_cuda $(F_HDF5_LIB_SEQ) $(FCURAND) -o $(APP)_cuda

$(APP)_mpi_cuda: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_mpi_cuda.a $(OPS_FILES_GEN) $(MPI_CUDA_OBJ)
		@echo ""
		@echo ""
		@echo "Building ${APP}_mpi_cuda"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI $(FMODS_CUDA) -c $(src) -o $(src:.F90=_mpi_cuda.o);)
		$(foreach src, $(CUDA_KERNELS), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI $(FMODS_CUDA) -c $(src) -o $(src:.CUF=_mpi_cuda.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI $(FMODS_CUDA) -c $(src) -o $(src:.F90=_mpi_cuda.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_CUDA) $(CUDAFOR) -DOPS_MPI $(I_MPI_INC) $(OTHER_MPI_CUDA_OBJ) $(MPI_CUDA_KERNELS_OBJ) $(MPI_CUDA_OPS_GENERATED_OBJ) $(APP_LIBS) $(FLINK) -lops_for_mpi_cuda $(F_HDF5_LIB_MPI) $(FCURAND) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_mpi_cuda

$(APP)_mpi_cuda_tiled: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_for_mpi_cuda.a $(OPS_FILES_GEN) $(MPI_CUDA_TILED_OBJ)
		@echo ""
		@echo ""
		@echo "Building ${APP}_mpi_cuda_tiled"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI -DOPS_LAZY $(FMODS_CUDA) -c $(src) -o $(src:.F90=_mpi_cuda_tiled.o);)
		$(foreach src, $(CUDA_KERNELS), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI -DOPS_LAZY $(FMODS_CUDA) -c $(src) -o $(src:.CUF=_mpi_cuda_tiled.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(CUDAFOR) -DOPS_MPI -DOPS_LAZY $(FMODS_CUDA) -c $(src) -o $(src:.F90=_mpi_cuda_tiled.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_CUDA) $(CUDAFOR) -DOPS_MPI -DOPS_LAZY $(I_MPI_INC) $(OTHER_MPI_CUDA_TILED_OBJ) $(MPI_CUDA_TILED_KERNELS_OBJ) $(MPI_CUDA_TILED_OPS_GENERATED_OBJ) $(APP_LIBS) $(FLINK) -lops_for_mpi_cuda $(F_HDF5_LIB_MPI) $(FCURAND) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_mpi_cuda_tiled

#=====================================================================================================================================================================
#
# F2C CUDA version
#
F2C_CUDA_FTN_KERNELS = $(wildcard f2c_cuda/*.F90)
F2C_CUDA_FTN_OBJS = $(F2C_CUDA_FTN_KERNELS:.F90=_f2c_cuda.o)

F2C_CUDA_CXX_MASTER_KERNELS = f2c_cuda/f2c_cuda_kernels.cu
F2C_CUDA_CXX_OBJS = $(F2C_CUDA_CXX_MASTER_KERNELS:.cu=_f2c_cuda.o)

F2C_CUDA_OTHER_OBJS = $(OTHER_FILES:.F90=_f2c_cuda.o)
F2C_CUDA_OPS_GEN_OBJS = $(OPS_GENERATED:.F90=_f2c_cuda.o)

$(F2C_CUDA_CXX_OBJS) : $(F2C_CUDA_CXX_MASTER_KERNELS)
	$(NVCC) $(F2C_NVCCFLAGS) -DOPS_FTN -I$(C_OPS_INC) -I. -c $< -o $@

$(APP)_f2c_cuda: Makefile .generated $(OPS_INSTALL_PATH)/fortran/lib/$(OPS_COMPILER)/libops_f2c_cuda.a $(OPS_FILES_GEN) $(F2C_CUDA_CXX_OBJS)
		@echo ""
		@echo ""
		@echo "Building ${APP}_f2c_cuda"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_CUDA) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_cuda.o);)
		$(foreach src, $(F2C_CUDA_FTN_KERNELS), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_CUDA) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_cuda.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_CUDA) -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_cuda.o);)
		$(MPIF90) $(FFLAGS) $(APP_FLAGS) -I$(CUDA_INC) -I$(C_OPS_INC) $(FMODS_F2C_CUDA) $(F2C_CUDA_CXX_OBJS) $(F2C_CUDA_OTHER_OBJS) $(F2C_CUDA_FTN_OBJS) $(F2C_CUDA_OPS_GEN_OBJS) $(APP_LIBS) $(FLINK) -lops_f2c_cuda $(F_HDF5_LIB_SEQ) -L$(CUDA_LIB) $(CUDART) $(CURAND) -o $(APP)_f2c_cuda


F2C_MPI_CUDA_FTN_OBJS = $(F2C_CUDA_FTN_KERNELS:.F90=_f2c_mpi_cuda.o)
F2C_MPI_CUDA_CXX_OBJS = $(F2C_CUDA_CXX_MASTER_KERNELS:.cu=_f2c_mpi_cuda.o)
F2C_MPI_CUDA_OTHER_OBJS = $(OTHER_FILES:.F90=_f2c_mpi_cuda.o)
F2C_MPI_CUDA_OPS_GEN_OBJS = $(OPS_GENERATED:.F90=_f2c_mpi_cuda.o)

$(F2C_MPI_CUDA_CXX_OBJS) : $(F2C_CUDA_CXX_MASTER_KERNELS)
	$(NVCC) $(F2C_NVCCFLAGS) -DOPS_FTN -DOPS_MPI -I$(C_OPS_INC) -I. -DMPICH_IGNORE_CXX_SEEK $(I_MPI_INC) -c $< -o $@

