		@echo "Building ${APP}_f2c_mpi_sycl_tiled"
		@echo ""
		$(foreach src, $(OTHER_FILES), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_SYCL) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_sycl_tiled.o);)
		$(foreach src, $(F2C_SYCL_FTN_KERNELS), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_SYCL) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_sycl_tiled.o);)
		$(foreach src, $(OPS_GENERATED), $(MPIF90) $(FFLAGS) $(APP_FLAGS) $(FMODS_F2C_SYCL) -DOPS_MPI -DOPS_LAZY -DOPS_F2C_INTEROP -c $(src) -o $(src:.F90=_f2c_mpi_sycl_tiled.o);)
		$(MPIF90) $(FFLAGS) $(SYCL_FLAGS) $(APP_FLAGS) -DOPS_MPI -DOPS_LAZY -I$(C_OPS_INC) $(FMODS_F2C_SYCL) $(I_MPI_INC) $(F2C_MPI_SYCL_TILED_CXX_OBJS) $(F2C_MPI_SYCL_TILED_OTHER_OBJS) $(F2C_MPI_SYCL_TILED_FTN_OBJS) $(F2C_MPI_SYCL_TILED_OPS_GEN_OBJS) $(APP_LIBS) $(FLINK) -lops_f2c_mpi_sycl $(F_HDF5_LIB_MPI) $(L_MPI_LIB) $(MPI_LINK) -o $(APP)_f2c_mpi_sycl_tiled

#=====================================================================================================================================================================
#
# cleanup
#

cleanall: clean
	rm -rf ./mpi_openmp ./cuda ./openmp_offload ./f2c_mpi_openmp ./f2c_cuda ./f2c_hip ./f2c_sycl

clean:
	rm -f *.o
	rm -f *.oo
	rm -f *.optrpt
	rm -f *.mod
	rm -f *~ *.acc.s
	rm -f $(APP)_seq
	rm -f $(APP)_tiled
	rm -f $(APP)_openmp
	rm -f $(APP)_mpi
	rm -f $(APP)_mpi_tiled
	rm -f $(APP)_mpi_openmp
	rm -f $(APP)_f2c_seq
	rm -f $(APP)_f2c_mpi
	rm -f $(APP)_f2c_mpi_tiled
	rm -f $(APP)_cuda
	rm -f $(APP)_mpi_cuda
	rm -f $(APP)_mpi_cuda_tiled
	rm -f $(APP)_f2c_cuda
	rm -f $(APP)_f2c_mpi_cuda
	rm -f $(APP)_f2c_mpi_cuda_tiled
	rm -f $(APP)_ompoffload
	rm -f $(APP)_mpi_ompoffload
	rm -f $(APP)_mpi_ompoffload_tiled
	rm -f $(APP)_f2c_hip
	rm -f $(APP)_f2c_mpi_hip
	rm -f $(APP)_f2c_mpi_hip_tiled
	rm -f $(APP)_f2c_sycl
	rm -f $(APP)_f2c_mpi_sycl
	rm -f $(APP)_f2c_mpi_sycl_tiled
	rm -f $(OPS_GENERATED)
	rm -f .generated constants_list.txt constants_offload.F90
